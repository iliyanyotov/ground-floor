{
  "name": "ground-floor",
  "version": "0.1.0",
  "private": false,
  "description": "Baseline dotfiles and configs for any TypeScript projects.",
  "type": "module",
  "scripts": {
    "prepare": "husky",
    "format": "biome format --write .",
    "lint": "biome lint .",
    "lint:fix": "biome check --fix .",
    "check": "biome check .",
    "type-check": "tsc --noEmit",
    "release": "standard-version"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.15",
    "@commitlint/cli": "21.0.1",
    "@commitlint/config-conventional": "21.0.1",
    "@types/bun": "1.3.14",
    "husky": "9.1.7",
    "lint-staged": "17.0.5",
    "standard-version": "9.5.0",
    "typescript": "6.0.3"
  },
  "engines": {
    "bun": ">=1.1.0"
  }
}
