{
  "name": "ground-floor",
  "version": "0.1.0",
  "private": false,
  "description": "Baseline dotfiles and configs for any TypeScript project",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "prepare": "husky",
    "format": "biome format --write .",
    "lint": "biome lint .",
    "lint:fix": "biome check --fix .",
    "check": "biome check .",
    "type-check": "tsc --noEmit",
    "test": "bun test",
    "release": "commit-and-tag-version"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.16",
    "@commitlint/cli": "21.0.2",
    "@commitlint/config-conventional": "21.0.2",
    "@types/bun": "1.3.14",
    "commit-and-tag-version": "12.7.3",
    "husky": "9.1.7",
    "lint-staged": "17.0.7",
    "typescript": "6.0.3"
  }
}
